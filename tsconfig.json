{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "exactOptionalPropertyTypes": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2024",
    "types": ["node", "vitest"],
    "verbatimModuleSyntax": true
  },
  "include": [
    "packages/**/*.ts",
    "packages/icons/src/*.tsx",
    "examples/drizzle-registry-runtime.ts",
    "examples/vite-kovo-compiler.ts",
    "vite.config.ts"
  ],
  "exclude": ["packages/create-kovo/templates/**"]
}
