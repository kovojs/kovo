{
  "name": "@kovojs/site",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "api:check": "node scripts/api-ref.mjs && node scripts/api-examples-check.mjs",
    "api:examples": "node scripts/api-examples-check.mjs",
    "api:ref": "node scripts/api-ref.mjs",
    "build": "node scripts/export-static.mjs",
    "build:css": "vp build",
    "check:links": "node scripts/check-links.mjs",
    "content": "node scripts/content-pipeline.mjs",
    "emit-routes": "node scripts/emit-routes.mjs",
    "serve": "node scripts/serve.mjs",
    "serve:static": "node scripts/serve-static.mjs",
    "test": "vitest --run"
  },
  "dependencies": {
    "@kovojs/core": "workspace:*",
    "@kovojs/runtime": "workspace:*",
    "@kovojs/server": "workspace:*"
  },
  "devDependencies": {
    "@kovojs/compiler": "workspace:*",
    "@kovojs/test": "workspace:*",
    "@kovojs/cli": "workspace:*",
    "marked": "^16.0.0",
    "shiki": "^3.0.0",
    "vite-plus": "^0.1.24",
    "vitest": "4.1.8"
  }
}
