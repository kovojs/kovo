{
  "name": "kovo-monorepo",
  "version": "0.1.1",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*",
    "conformance/*",
    "site",
    "tests/integration"
  ],
  "type": "module",
  "scripts": {
    "acceptance": "pnpm run check && pnpm run check:api-surface && pnpm run test && pnpm run test:browser && pnpm run test:gallery-browser && pnpm run test:integration && pnpm run check:build && pnpm run check:publish && pnpm run test:p10-perf && pnpm run test:compiler-perf && pnpm run test:conformance && pnpm run check:kovo",
    "check": "pnpm run check:inline-loader && pnpm run check:imports && pnpm run check:no-committed-generated && vp check && vp run typecheck-examples",
    "check:api-surface": "node scripts/api-surface-gate.mjs",
    "check:build": "pnpm run check:inline-loader && vp run build",
    "check:exports": "node scripts/exported-symbols.mjs --duplicates --check",
    "check:imports": "node scripts/import-boundary.mjs",
    "check:publish": "node scripts/build-publish.mjs",
    "check:kovo": "vp run kovo-check",
    "check:no-committed-generated": "node scripts/no-committed-generated.mjs",
    "check:inline-loader": "pnpm --filter @kovojs/browser run check:inline-loader",
    "bump": "node scripts/bump.mjs",
    "docs:serve": "pnpm run check:build && pnpm --filter @kovojs/site run build && HOST=0.0.0.0 node site/scripts/serve.mjs",
    "test": "vitest --run",
    "test:browser": "vp run browser",
    "test:gallery-browser": "pnpm --filter @kovojs/example-gallery run test:browser",
    "test:examples-live": "pnpm --filter @kovojs/site run test:examples-live",
    "test:compiler-perf": "vp run compiler-perf",
    "test:conformance": "vp run conformance",
    "test:integration": "vp run integration",
    "test:p10-perf": "vp run p10-perf",
    "symbols": "node scripts/exported-symbols.mjs"
  },
  "devDependencies": {
    "@kovojs/test": "workspace:*",
    "@playwright/test": "1.60.0",
    "@types/node": "25.9.2",
    "@typescript/native-preview": "7.0.0-dev.20260610.1",
    "@vitest/browser-playwright": "4.1.8",
    "playwright": "^1.60.0",
    "typescript": "^6.0.3",
    "vite-plus": "0.1.24",
    "vitest": "4.1.8"
  },
  "packageManager": "pnpm@10.12.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
