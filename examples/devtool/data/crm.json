    {
      "id": "query:queries/contact-list-query",
      "kind": "query",
      "name": "queries/contact-list-query",
      "label": "queries/contact-list-query",
      "data": { "domains": ["model/contact"], "guards": [] },
      "source": {
        "file": "queries.ts",
        "startLine": 89,
        "anchorLine": 90,
        "endLine": 105,
        "code": "/** AGG(contacts) — the full contact book, ordered by id (a derivable rowset). */\nexport const queries/contact-list-queryQuery = query({\n  reads: [contact],\n  load: async (_input: unknown, db: CrmDb): Promise<ContactListResult> => {\n    const items = await db\n      .select({\n        id: contacts.id,\n        name: contacts.name,\n        email: contacts.email,\n        ownerId: contacts.ownerId,\n        dealCount: contacts.dealCount,\n      })\n      .from(contacts)\n      .orderBy(contacts.id);\n    return { items: items };\n  },\n});",
        "lang": "ts"
      }
    },
    {
      "id": "query:queries/deal-list-query",
      "kind": "query",
      "name": "queries/deal-list-query",
      "label": "queries/deal-list-query",
      "data": { "domains": ["model/deal"], "guards": [] },
      "source": {
        "file": "queries.ts",
        "startLine": 107,
        "anchorLine": 108,
        "endLine": 123,
        "code": "/** AGG(deals) ordered by id — the full pipeline list (a derivable rowset). */\nexport const queries/deal-list-queryQuery = query({\n  reads: [deal],\n  load: async (_input: unknown, db: CrmDb): Promise<DealListResult> => {\n    const items = await db\n      .select({\n        id: deals.id,\n        contactId: deals.contactId,\n        stage: deals.stage,\n        amount: deals.amount,\n        ownerId: deals.ownerId,\n      })\n      .from(deals)\n      .orderBy(deals.id);\n    return { items: items };\n  },\n});",
        "lang": "ts"
      }
    },
    {
      "id": "query:queries/contact-deal-count-query",
      "kind": "query",
      "name": "queries/contact-deal-count-query",
      "label": "queries/contact-deal-count-query",
      "data": { "domains": ["model/deal"], "guards": [] },
      "source": {
        "file": "queries.ts",
        "startLine": 125,
        "anchorLine": 126,
        "endLine": 132,
        "code": "/** COUNT(deals) — the scalar count of deals across the pipeline (derivable). */\nexport const queries/contact-deal-count-queryQuery = query({\n  reads: [deal],\n  load: async (_input: unknown, db: CrmDb): Promise<ContactDealCountResult> => {\n    const rows = await db.select({ value: count() }).from(deals);\n    return { count: Number(rows[0]?.value ?? 0) };\n  },\n});",
        "lang": "ts"
      }
    },
    {
      "id": "query:queries/open-deals-query",
      "kind": "query",
      "name": "queries/open-deals-query",
      "label": "queries/open-deals-query",
      "data": { "domains": ["model/deal"], "guards": [] },
      "source": {
        "file": "queries.ts",
        "startLine": 134,
        "anchorLine": 135,
        "endLine": 151,
        "code": "/** AGG(deals WHERE stage = 'open') — the open pipeline (a filtered rowset). */\nexport const queries/open-deals-queryQuery = query({\n  reads: [deal],\n  load: async (_input: unknown, db: CrmDb): Promise<OpenDealsResult> => {\n    const items = await db\n      .select({\n        id: deals.id,\n        contactId: deals.contactId,\n        stage: deals.stage,\n        amount: deals.amount,\n        ownerId: deals.ownerId,\n      })\n      .from(deals)\n      .where(eq(deals.stage, 'open'))\n      .orderBy(deals.id);\n    return { items: items };\n  },\n});",
        "lang": "ts"
      }
    },
    {
      "id": "query:queries/pipeline-by-stage-query",
      "kind": "query",
      "name": "queries/pipeline-by-stage-query",
      "label": "queries/pipeline-by-stage-query",
      "data": { "domains": ["model/deal"], "guards": [] },
      "source": {
        "file": "queries.ts",
        "startLine": 153,
        "anchorLine": 156,
        "endLine": 166,
        "code": "/**\n * SUM(amount) GROUP BY stage — the pipeline value per stage.\n */\nexport const queries/pipeline-by-stage-queryQuery = query({\n  reads: [deal],\n  load: async (_input: unknown, db: CrmDb): Promise<PipelineByStageResult> => {\n    const buckets = await db\n      .select({ stage: deals.stage, total: sql<number>`coalesce(sum(${deals.amount}), 0)::int` })\n      .from(deals)\n      .groupBy(deals.stage)\n      .orderBy(deals.stage);\n    return { buckets: buckets };\n  },\n});",
        "lang": "ts"
      }
    }
  ],
