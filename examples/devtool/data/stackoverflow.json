    {
      "id": "query:questionList",
      "kind": "query",
      "name": "questionList",
      "label": "questionList",
      "data": { "domains": ["question"], "guards": [] },
      "source": {
        "file": "queries.ts",
        "startLine": 20,
        "anchorLine": 22,
        "endLine": 43,
        "code": "// The list is ordered by stable id so a vote changes the score without reshuffling\n// rows while a fragment response is being applied.\nexport const questionList = query('questionList', {\n  load: async (_input: unknown, context?: SoQueryLoadContext) => {\n    const db = requireSoQueryDb(context);\n    const items = await db\n      .select({\n        authorId: questions.authorId,\n        authorName: questions.authorName,\n        body: questions.body,\n        createdAt: questions.createdAt,\n        id: questions.id,\n        tags: questions.tags,\n        title: questions.title,\n        score: questions.score,\n        answerCount: questions.answerCount,\n      })\n      .from(questions)\n      .orderBy(questions.id);\n    // Keep the explicit property for the artifact generator.\n    return { items: items };\n  },\n  reads: [question],\n});",
        "lang": "ts"
      }
    },
    {
      "id": "query:answerList",
      "kind": "query",
      "name": "answerList",
      "label": "answerList",
      "data": { "domains": ["answer"], "guards": [] },
      "source": {
        "file": "queries.ts",
        "startLine": 45,
        "anchorLine": 46,
        "endLine": 61,
        "code": "// All answers, ordered by stable id.\nexport const answerList = query('answerList', {\n  load: async (_input: unknown, context?: SoQueryLoadContext) => {\n    const db = requireSoQueryDb(context);\n    const items = await db\n      .select({\n        id: answers.id,\n        questionId: answers.questionId,\n        body: answers.body,\n        score: answers.score,\n      })\n      .from(answers)\n      .orderBy(answers.id);\n    return { items: items };\n  },\n  reads: [answer],\n});",
        "lang": "ts"
      }
    },
    {
      "id": "query:questionDetail",
      "kind": "query",
      "name": "questionDetail",
      "label": "questionDetail",
      "data": { "domains": ["question"], "guards": [] },
      "source": {
        "file": "queries.ts",
        "startLine": 63,
        "anchorLine": 63,
        "endLine": 88,
        "code": "export const questionDetail = query('questionDetail', {\n  args: s.object({ id: s.string() }),\n  load: async (\n    input: { id: string },\n    context?: SoQueryLoadContext,\n  ): Promise<QuestionDetailResult | null> => {\n    const db = requireSoQueryDb(context);\n    const [row] = await db\n      .select({\n        id: questions.id,\n        title: questions.title,\n        body: questions.body,\n        authorId: questions.authorId,\n        score: questions.score,\n        answerCount: questions.answerCount,\n        authorName: questions.authorName,\n        tags: questions.tags,\n        createdAt: questions.createdAt,\n      })\n      .from(questions)\n      .where(eq(questions.id, input.id))\n      .limit(1);\n    return row ?? null;\n  },\n  reads: [question],\n});",
        "lang": "ts"
      }
    },
    {
      "id": "query:questionAnswers",
      "kind": "query",
      "name": "questionAnswers",
      "label": "questionAnswers",
      "data": { "domains": ["answer"], "guards": [] },
      "source": {
        "file": "queries.ts",
        "startLine": 90,
        "anchorLine": 90,
        "endLine": 113,
        "code": "export const questionAnswers = query('questionAnswers', {\n  args: s.object({ questionId: s.string() }),\n  load: async (\n    input: { questionId: string },\n    context?: SoQueryLoadContext,\n  ): Promise<QuestionAnswersResult> => {\n    const db = requireSoQueryDb(context);\n    return db\n      .select({\n        id: answers.id,\n        questionId: answers.questionId,\n        body: answers.body,\n        score: answers.score,\n        accepted: answers.accepted,\n        authorId: answers.authorId,\n        authorName: answers.authorName,\n        createdAt: answers.createdAt,\n      })\n      .from(answers)\n      .where(eq(answers.questionId, input.questionId))\n      .orderBy(asc(answers.id));\n  },\n  reads: [answer],\n});",
        "lang": "ts"
      }
    },
    {
      "id": "query:questionScore",
      "kind": "query",
      "name": "questionScore",
      "label": "questionScore",
      "data": { "domains": ["vote"], "guards": [] },
      "source": {
        "file": "queries.ts",
        "startLine": 115,
        "anchorLine": 116,
        "endLine": 123,
        "code": "// Total score across all question votes.\nexport const questionScore = query('questionScore', {\n  load: async (_input: unknown, context?: SoQueryLoadContext) => {\n    const db = requireSoQueryDb(context);\n    const rows = await db.select({ value: sum(votes.value) }).from(votes);\n    return { score: Number(rows[0]?.value ?? 0) };\n  },\n  reads: [vote],\n});",
        "lang": "ts"
      }
    }
