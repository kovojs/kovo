{
  "name": "@kovojs/example-devtool",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "vp check",
    "conformance": "node scripts/emit-example-graphs.mjs && node scripts/conformance.mjs",
    "dev": "node scripts/emit-example-graphs.mjs && vp dev",
    "dev:mounted": "node scripts/emit-example-graphs.mjs && KOVO_DEVTOOL_BASE=/__kovo vp dev",
    "emit-example-graphs": "node scripts/emit-example-graphs.mjs",
    "mcp": "node scripts/emit-example-graphs.mjs && kovo-devtool mcp --graph ../commerce/src/generated/graph.json --src ../commerce/src --label Commerce --graph ../crm/src/generated/graph.json --src ../crm/src --label CRM --graph ../stackoverflow/src/generated/graph.json --src ../stackoverflow/src --label 'Stack Overflow'",
    "test": "vp test",
    "test:mcp": "node scripts/emit-example-graphs.mjs && node scripts/test-mcp.mjs"
  },
  "dependencies": {
    "@kovojs/devtool": "workspace:*",
    "@kovojs/runtime": "workspace:*",
    "@kovojs/server": "workspace:*"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^25.0.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.16",
    "vite-plus": "^0.1.24",
    "vitest": "^4.1.8"
  }
}
