{
  "name": "@kovojs/drizzle",
  "version": "0.1.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./src/runtime.ts",
    "./derive": "./src/derive.ts",
    "./static": "./src/static.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/runtime.d.mts",
        "default": "./dist/runtime.mjs"
      },
      "./derive": {
        "types": "./dist/derive.d.mts",
        "default": "./dist/derive.mjs"
      },
      "./static": {
        "types": "./dist/static.d.mts",
        "default": "./dist/static.mjs"
      }
    }
  },
  "scripts": {
    "build:dist": "vp pack src/derive.ts src/runtime.ts src/static.ts --dts",
    "prepack": "pnpm run build:dist"
  },
  "dependencies": {
    "@kovojs/core": "workspace:*",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "drizzle-orm": "0.45.2",
    "vitest": "4.1.8"
  },
  "peerDependencies": {
    "drizzle-orm": ">=0.45.2 <1"
  }
}
