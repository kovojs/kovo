{
  "name": "@kovojs/drizzle",
  "version": "0.1.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kovojs/kovo.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./src/runtime.ts",
    "./internal/derive": "./src/derive.ts",
    "./internal/derive-codegen": "./src/derive-codegen.ts",
    "./internal/static": "./src/static.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/runtime.d.mts",
        "default": "./dist/runtime.mjs"
      },
      "./internal/derive": {
        "types": "./dist/derive.d.mts",
        "default": "./dist/derive.mjs"
      },
      "./internal/derive-codegen": {
        "types": "./dist/derive-codegen.d.mts",
        "default": "./dist/derive-codegen.mjs"
      },
      "./internal/static": {
        "types": "./dist/static.d.mts",
        "default": "./dist/static.mjs"
      }
    }
  },
  "scripts": {
    "build:dist": "vp pack src/derive-codegen.ts src/derive.ts src/runtime.ts src/static.ts --dts",
    "prepack": "pnpm run build:dist"
  },
  "dependencies": {
    "@kovojs/core": "workspace:*",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "drizzle-orm": "1.0.0-rc.3",
    "vitest": "4.1.8"
  },
  "peerDependencies": {
    "drizzle-orm": ">=1.0.0-rc.3 <2"
  }
}
