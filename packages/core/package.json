{
  "name": "@kovojs/core",
  "version": "0.1.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./internal/derivation": "./src/internal/derivation.ts",
    "./internal/graph": "./src/internal/graph.ts",
    "./internal/package-prefix": "./src/internal/package-prefix.ts",
    "./internal/query-delta": "./src/internal/query-delta.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "./internal/derivation": {
        "types": "./dist/internal/derivation.d.mts",
        "default": "./dist/internal/derivation.mjs"
      },
      "./internal/graph": {
        "types": "./dist/internal/graph.d.mts",
        "default": "./dist/internal/graph.mjs"
      },
      "./internal/package-prefix": {
        "types": "./dist/internal/package-prefix.d.mts",
        "default": "./dist/internal/package-prefix.mjs"
      },
      "./internal/query-delta": {
        "types": "./dist/internal/query-delta.d.mts",
        "default": "./dist/internal/query-delta.mjs"
      }
    }
  },
  "scripts": {
    "build:dist": "vp pack src/index.ts src/internal/derivation.ts src/internal/graph.ts src/internal/package-prefix.ts src/internal/query-delta.ts --dts",
    "prepack": "pnpm run build:dist"
  },
  "devDependencies": {
    "vitest": "4.1.8"
  }
}
