        "default": "./dist/internal/client-module-url.mjs"
      },
      "./internal/derivation": {
        "types": "./dist/internal/derivation.d.mts",
        "default": "./dist/internal/derivation.mjs"
      },
      "./internal/diagnostics": {
        "types": "./dist/internal/diagnostics.d.mts",
        "default": "./dist/internal/diagnostics.mjs"
      },
      "./internal/document-protocol": {
        "types": "./dist/internal/document-protocol.d.mts",
        "default": "./dist/internal/document-protocol.mjs"
      },
      "./internal/event": {
        "types": "./dist/internal/event.d.mts",
        "default": "./dist/internal/event.mjs"
      },
      "./internal/fragment-target": {
        "types": "./dist/internal/fragment-target.d.mts",
        "default": "./dist/internal/fragment-target.mjs"
      },
      "./internal/graph": {
        "types": "./dist/internal/graph.d.mts",
        "default": "./dist/internal/graph.mjs"
      },
      "./internal/package-prefix": {
        "types": "./dist/internal/package-prefix.d.mts",
        "default": "./dist/internal/package-prefix.mjs"
      },
      "./internal/query-delta": {
        "types": "./dist/internal/query-delta.d.mts",
        "default": "./dist/internal/query-delta.mjs"
      },
      "./internal/render-plan-token": {
        "types": "./dist/internal/render-plan-token.d.mts",
        "default": "./dist/internal/render-plan-token.mjs"
      },
      "./internal/security-url": {
        "types": "./dist/internal/security-url.d.mts",
        "default": "./dist/internal/security-url.mjs"
