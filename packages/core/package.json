  "version": "0.1.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kovojs/kovo.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./generated": "./src/generated.ts",
    "./internal/component-render": "./src/internal/component-render.ts",
    "./internal/agent-docs": "./src/internal/agent-docs.ts",
    "./internal/client-module-url": "./src/internal/client-module-url.ts",
    "./internal/derivation": "./src/internal/derivation.ts",
    "./internal/diagnostics": "./src/internal/diagnostics.ts",
    "./internal/document-protocol": "./src/internal/document-protocol.ts",
    "./internal/event": "./src/internal/event.ts",
    "./internal/fragment-target": "./src/internal/fragment-target.ts",
