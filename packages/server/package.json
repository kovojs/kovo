{
  "name": "@kovojs/server",
  "version": "0.1.3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kovojs/kovo.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./build": "./src/build.ts",
    "./testing": "./src/testing.ts",
    "./vite": "./src/vite.ts",
    "./internal/app-shell-vite": "./src/internal/app-shell-vite.ts",
    "./internal/build": "./src/internal/build.ts",
    "./internal/build-context": "./src/internal/build-context.ts",
    "./internal/client-modules": "./src/internal/client-modules.ts",
    "./internal/csrf": "./src/internal/csrf.ts",
