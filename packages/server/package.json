        "types": "./dist/internal/data-plane-static-analysis.d.mts",
        "default": "./dist/internal/data-plane-static-analysis.mjs"
      },
      "./internal/escape": {
        "types": "./dist/internal/escape.d.mts",
        "default": "./dist/internal/escape.mjs"
      },
      "./internal/execution": {
        "types": "./dist/internal/execution.d.mts",
        "default": "./dist/internal/execution.mjs"
      },
      "./internal/html": {
        "types": "./dist/internal/html.d.mts",
        "default": "./dist/internal/html.mjs"
      },
      "./internal/runtime-registry-wire": {
        "types": "./dist/internal/runtime-registry-wire.d.mts",
        "default": "./dist/internal/runtime-registry-wire.mjs"
      },
      "./internal/route": {
        "types": "./dist/internal/route.d.mts",
        "default": "./dist/internal/route.mjs"
