    "./internal/execution": "./src/internal/execution.ts",
    "./internal/html": "./src/internal/html.ts",
    "./internal/runtime-registry-wire": "./src/internal/runtime-registry-wire.ts",
    "./internal/route": "./src/internal/route.ts",
    "./internal/static-export": "./src/internal/static-export.ts",
