        "types": "./dist/internal/app-shell-vite.d.mts",
        "default": "./dist/internal/app-shell-vite.mjs"
      },
      "./internal/build": {
        "types": "./dist/internal/build.d.mts",
        "default": "./dist/internal/build.mjs"
      },
      "./internal/build-context": {
        "types": "./dist/internal/build-context.d.mts",
        "default": "./dist/internal/build-context.mjs"
