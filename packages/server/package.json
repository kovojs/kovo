      "./jsx-runtime": {
        "types": "./dist/jsx-runtime.d.mts",
        "default": "./dist/jsx-runtime.mjs"
      },
      "./jsx-dev-runtime": {
        "types": "./dist/jsx-runtime.d.mts",
        "default": "./dist/jsx-runtime.mjs"
      }
    }
  },
  "scripts": {
    "build:dist": "vp pack src/build.ts src/index.ts src/internal/app-shell-vite.ts src/internal/build.ts src/internal/build-context.ts src/internal/client-modules.ts src/internal/csrf.ts src/internal/data-plane-static-analysis.ts src/internal/escape.ts src/internal/execution.ts src/internal/html.ts src/internal/runtime-registry-wire.ts src/internal/route.ts src/internal/static-export.ts src/internal/wire.ts src/jsx-runtime.ts src/testing.ts src/vite.ts --dts",
