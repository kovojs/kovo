{
  "name": "@kovojs/browser",
  "version": "0.1.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kovojs/kovo.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./generated": "./src/generated.ts",
    "./internal/delegation": "./src/internal/delegation.ts",
    "./internal/inline-loader": "./src/internal/inline-loader.ts",
    "./internal/morph": "./src/internal/morph.ts",
    "./internal/mutation": "./src/internal/mutation.ts",
    "./internal/output": "./src/internal/output.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "./client": {
        "types": "./dist/client.d.mts",
        "default": "./dist/client.mjs"
      },
      "./generated": {
        "types": "./dist/generated.d.mts",
        "default": "./dist/generated.mjs"
      },
      "./internal/delegation": {
        "types": "./dist/internal/delegation.d.mts",
        "default": "./dist/internal/delegation.mjs"
      },
      "./internal/inline-loader": {
        "types": "./dist/internal/inline-loader.d.mts",
        "default": "./dist/internal/inline-loader.mjs"
      },
      "./internal/morph": {
        "types": "./dist/internal/morph.d.mts",
        "default": "./dist/internal/morph.mjs"
      },
      "./internal/mutation": {
        "types": "./dist/internal/mutation.d.mts",
        "default": "./dist/internal/mutation.mjs"
      },
      "./internal/output": {
        "types": "./dist/internal/output.d.mts",
        "default": "./dist/internal/output.mjs"
      }
    }
  },
  "scripts": {
    "build": "pnpm run build:inline-loader",
    "build:inline-loader": "node --experimental-strip-types src/inline-loader-build.ts",
    "check": "pnpm run check:inline-loader",
    "check:inline-loader:trusted-types": "vitest run src/inline-loader-trusted-types-routing.test.ts",
    "check:inline-loader": "node --experimental-strip-types src/inline-loader-build.ts --check",
    "build:dist": "vp pack src/client.ts src/generated.ts src/index.ts src/internal/delegation.ts src/internal/inline-loader.ts src/internal/morph.ts src/internal/mutation.ts src/internal/output.ts --dts",
    "prepack": "pnpm run build:dist"
  },
  "dependencies": {
    "@kovojs/core": "workspace:*"
  },
  "devDependencies": {
    "vitest": "4.1.8"
  }
}
