{
  "name": "@kovojs/compiler",
  "version": "0.2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kovojs/kovo.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./graph": "./src/graph.ts",
    "./internal": "./src/internal.ts",
    "./internal/graph": "./src/internal/graph.ts",
    "./internal/security-bootstrap": "./src/security-bootstrap.ts",
    "./internal/source-filesystem": "./src/source-filesystem.ts",
    "./package-styles": "./src/package-styles.ts",
    "./vite": "./src/vite-config.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "./graph": {
        "types": "./dist/graph.d.mts",
        "default": "./dist/graph.mjs"
      },
      "./internal": {
        "types": "./dist/internal.d.mts",
        "default": "./dist/internal.mjs"
      },
      "./internal/graph": {
        "types": "./dist/internal/graph.d.mts",
        "default": "./dist/internal/graph.mjs"
      },
      "./internal/security-bootstrap": {
        "types": "./dist/security-bootstrap.d.mts",
        "default": "./dist/security-bootstrap.mjs"
      },
      "./internal/source-filesystem": {
        "types": "./dist/source-filesystem.d.mts",
        "default": "./dist/source-filesystem.mjs"
      },
      "./package-styles": {
        "types": "./dist/package-styles.d.mts",
        "default": "./dist/package-styles.mjs"
      },
      "./vite": {
        "types": "./dist/vite-config.d.mts",
        "default": "./dist/vite-config.mjs"
      }
    }
  },
  "scripts": {
    "build:dist": "vp pack src/compile.ts src/graph.ts src/index.ts src/internal.ts src/internal/graph.ts src/package-styles.ts src/security-bootstrap.ts src/source-filesystem.ts src/vite-config.ts --dts",
    "gen:reactive-attrs": "node scripts/gen-primitive-reactive-attrs.mjs",
    "prepack": "pnpm run build:dist"
  },
  "dependencies": {
    "@kovojs/core": "workspace:*",
    "@kovojs/style": "workspace:*",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@kovojs/browser": "workspace:*",
    "@kovojs/headless-ui": "workspace:*",
    "@kovojs/server": "workspace:*",
    "vitest": "4.1.8"
  },
  "kovo": {
    "publishExtraEntries": [
      "./src/compile.ts"
    ]
  }
}
