{
  "name": "@kovojs/icons",
  "version": "0.1.3",
  "description": "The Lucide icon set as native Kovo SVG components — one tree-shakeable component per icon.",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kovojs/kovo.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.tsx",
    "./index": null,
    "./*": "./src/*.tsx"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "./index": null,
      "./*": {
        "types": "./dist/*.d.mts",
        "default": "./dist/*.mjs"
      }
    }
  },
  "scripts": {
    "build:icons": "node ../../scripts/build-icons.mjs",
    "build:dist": "node ./scripts/build-dist.mjs",
    "prepack": "pnpm run build:dist"
  },
  "dependencies": {
    "@kovojs/server": "workspace:*",
    "@kovojs/style": "workspace:*"
  },
  "devDependencies": {
    "lucide-static": "1.21.0",
    "vitest": "4.1.8"
  }
}
