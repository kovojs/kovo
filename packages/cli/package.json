{
  "name": "@kovojs/cli",
  "version": "0.1.0",
  "bin": {
    "kovo": "./src/bin.ts"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./src/api.ts",
    "./internal": "./src/index.ts"
  },
  "publishConfig": {
    "bin": {
      "kovo": "./dist/bin.mjs"
    },
    "exports": {
      ".": {
        "types": "./dist/api.d.mts",
        "default": "./dist/api.mjs"
      },
      "./internal": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "build:dist": "vp pack src/api.ts src/bin.ts src/index.ts --dts",
    "prepack": "pnpm run build:dist"
  },
  "dependencies": {
    "@kovojs/compiler": "workspace:*",
    "@kovojs/core": "workspace:*",
    "@kovojs/drizzle": "workspace:*",
    "@kovojs/headless-ui": "workspace:*",
    "@kovojs/server": "workspace:*",
    "@kovojs/ui": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "vite-plus": "0.1.24"
  },
  "devDependencies": {
    "vitest": "4.1.8"
  }
}
