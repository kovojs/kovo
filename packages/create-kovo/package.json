{
  "name": "create-kovo",
  "version": "0.2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kovojs/kovo.git"
  },
  "bin": {
    "create-kovo": "./src/index.ts"
  },
  "files": [
    "dist",
    "templates"
  ],
  "type": "module",
  "publishConfig": {
    "bin": {
      "create-kovo": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build:dist": "vp pack src/index.ts --dts",
    "prepack": "pnpm run build:dist"
  },
  "dependencies": {
    "@kovojs/core": "workspace:*"
  },
  "devDependencies": {
    "@kovojs/better-auth": "workspace:*",
    "@kovojs/browser": "workspace:*",
    "@kovojs/cli": "workspace:*",
    "@kovojs/compiler": "workspace:*",
    "@kovojs/server": "workspace:*",
    "@kovojs/style": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "12.11.1",
    "vite": "8.0.16",
    "vite-plus": "0.1.24",
    "vitest": "4.1.8"
  },
  "kovo": {
    "starterPackageManager": "pnpm@10.12.1"
  }
}
