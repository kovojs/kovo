{
  "name": "{{name}}",
  "private": true,
  "type": "module",
  "scripts": {
    "build:prod": "kovo build ./src/app.tsx",
    "check": "node scripts/check-parallel.mjs",
    "check:endpoint-posture": "vitest run src/endpoint-posture.test.ts && kovo check endpoint-posture .kovo/endpoint-posture.json",
    "check:sound-subset": "node scripts/check-sound-subset.mjs",
    "dev": "kovo dev ./src/app.tsx",
    "serve": "pnpm run build:prod && node dist/server/server.mjs",
    "start": "node dist/server/server.mjs",
    "test": "vp test"
  },
  "dependencies": {
    "@kovojs/better-auth": "{{kovo_better_auth_version}}",
    "@kovojs/browser": "{{kovo_browser_version}}",
    "@kovojs/core": "{{kovo_core_version}}",
    "@kovojs/drizzle": "{{kovo_drizzle_version}}",
    "@kovojs/server": "{{kovo_server_version}}",
    "@kovojs/style": "{{kovo_style_version}}",
    "@kovojs/ui": "{{kovo_ui_version}}",
    "better-auth": "1.6.17",
    "better-sqlite3": "12.11.1",
    "drizzle-orm": "1.0.0-rc.4",
    "pgsql-ast-parser": "^12.0.2"
  },
  "devDependencies": {
    "@kovojs/cli": "{{kovo_cli_version}}",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260610.1",
    "typescript": "^6.0.0",
    "vite": "^8.0.16",
    "vite-plus": "^0.1.24",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22.15.0"
  },
  "packageManager": "{{package_manager}}",
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3"]
  }
}
