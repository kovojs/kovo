{
  "name": "{{name}}",
  "private": true,
  "packageManager": "{{package_manager}}",
  "type": "module",
  "scripts": {
    "build:prod": "kovo build ./src/app.tsx",
    "check": "vp check && npm run check:sound-subset",
    "check:sound-subset": "node scripts/check-sound-subset.mjs",
    "dev": "vp dev",
    "serve": "npm run build:prod && node dist/server/server.mjs",
    "start": "node dist/server/server.mjs",
    "test": "vp test"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.1",
    "@kovojs/better-auth": "{{kovo_better_auth_version}}",
    "@kovojs/browser": "{{kovo_browser_version}}",
    "@kovojs/core": "{{kovo_core_version}}",
    "@kovojs/drizzle": "{{kovo_drizzle_version}}",
    "@kovojs/server": "{{kovo_server_version}}",
    "@kovojs/style": "{{kovo_style_version}}",
    "@kovojs/ui": "{{kovo_ui_version}}",
    "better-auth": "1.6.17",
    "drizzle-orm": "1.0.0-rc.3"
  },
  "devDependencies": {
    "@kovojs/cli": "{{kovo_cli_version}}",
    "@types/node": "^25.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260610.1",
    "typescript": "^6.0.0",
    "vite": "^8.0.16",
    "vite-plus": "^0.1.24",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22.15.0"
  }
}
