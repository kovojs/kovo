{
  "name": "@kovojs/better-auth",
  "version": "0.1.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kovojs/kovo.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./internal": "./src/internal.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "./internal": {
        "types": "./dist/internal.d.mts",
        "default": "./dist/internal.mjs"
      }
    }
  },
  "scripts": {
    "build:dist": "vp pack src/index.ts src/internal.ts --dts",
    "prepack": "pnpm run build:dist"
  },
  "dependencies": {
    "@kovojs/server": "workspace:*"
  },
  "devDependencies": {
    "better-auth": "1.6.17",
    "vitest": "4.1.8"
  },
  "peerDependencies": {
    "better-auth": "^1.6.0"
  }
}
